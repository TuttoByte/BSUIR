    <SolidColorBrush x:Key="BgColor" Color="#fafbff"/>
    <SolidColorBrush x:Key="TextColor" Color="#202121"/> 
    <Color x:Key="ShadowColor">#0982e9</Color>
    
    
</ResourceDictionary>
